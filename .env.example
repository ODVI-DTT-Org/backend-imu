# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/imu_db

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-min-32-characters
JWT_EXPIRY_HOURS=720
JWT_REFRESH_EXPIRY_DAYS=30

# Server Configuration
PORT=3000
NODE_ENV=development

# PowerSync Configuration
# For PowerSync Cloud: https://your-instance.powersync.co
# For self-hosted: http://localhost:3000/powersync
POWERSYNC_URL=http://localhost:3000/powersync
POWERSYNC_ENABLED=false

# CORS Configuration
CORS_ORIGIN=http://localhost:9999,http://localhost:8080

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=debug

# Redis Configuration (for BullMQ queues)
# Connection string format: redis://[password@]host:port/db
REDIS_URL=redis://localhost:6379/0
# Alternative: Use individual parameters (Redis URL takes precedence)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Queue Configuration
QUEUE_CONCURRENCY_BULK_OPERATIONS=5
QUEUE_CONCURRENCY_REPORTS=2
QUEUE_CONCURRENCY_LOCATIONS=3
QUEUE_CONCURRENCY_SYNC=10
