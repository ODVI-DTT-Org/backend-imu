# ===========================================
# IMU Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# -------------------
# Database Configuration
# -------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# -------------------
# JWT Configuration
# -------------------
# Secret for HS256 tokens (legacy backward compatibility)
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# -------------------
# PowerSync Configuration
# -------------------
# PowerSync instance URL from your dashboard
POWERSYNC_URL=http://localhost:8080
POWERSYNC_ENABLED=true

# PowerSync JWT Signing Keys (RS256)
# Generate new keys with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the private key below as a single line with \n for newlines
# or use a multiline string (platform-dependent)
POWERSYNC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE_REPLACE_WITH_ACTUAL_KEY
-----END PRIVATE KEY-----"

# Public key (optional - will use private key for verification if not provided)
POWERSYNC_PUBLIC_KEY=""

# -------------------
# Redis Configuration
# -------------------
# Redis connection string
# Format: redis://[[username:]password@]host:port/db
# Examples:
#   redis://localhost:6379/0
#   redis://:password@localhost:6379/0
#   rediss://:password@your-redis-cloud.com:6379/0 (for TLS)
REDIS_URL=redis://localhost:6379/0

# Redis configuration options
REDIS_ENABLED=true
REDIS_DB_INDEX=0
REDIS_KEY_PREFIX=imu:
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# Redis TLS (for cloud Redis providers)
REDIS_TLS=false

# -------------------
# Server Configuration
# -------------------
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development

# -------------------
# CORS Configuration
# -------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:9999,http://localhost:8080,http://localhost:5000,http://localhost:4002

# -------------------
# File Upload Configuration
# -------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# -------------------
# Logging
# -------------------
LOG_LEVEL=debug

# -------------------
# AWS Configuration (optional)
# -------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# -------------------
# Email Configuration (optional)
# -------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@imu.com

# -------------------
# Mapbox Configuration (for Flutter app)
# -------------------
# Get your access token from https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12
MAP_DEFAULT_ZOOM=15.0
MAP_MIN_ZOOM=10.0
MAP_MAX_ZOOM=20.0
