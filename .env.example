# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/imu_db

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-min-32-characters
JWT_EXPIRY_HOURS=720
JWT_REFRESH_EXPIRY_DAYS=30

# Server Configuration
PORT=3000
NODE_ENV=development

# PowerSync Configuration
# For PowerSync Cloud: https://your-instance.powersync.co
# For self-hosted: http://localhost:3000/powersync
POWERSYNC_URL=http://localhost:3000/powersync
POWERSYNC_ENABLED=false

# CORS Configuration
CORS_ORIGIN=http://localhost:9999,http://localhost:8080

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=debug

# Redis Configuration
# Used for: BullMQ job queues, response caching, session management, IMU client caching
# Connection string format: redis://[password@]host:port/db
REDIS_URL=redis://localhost:6379/0
# Alternative: Use individual parameters (Redis URL takes precedence)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Redis Caching Configuration (IMU Client Caching)
# Enable/disable Redis caching for assigned clients and touchpoint summaries
REDIS_ENABLED=true
# Redis database index (0-15)
REDIS_DB_INDEX=0
# Key prefix for cache keys (useful for multi-tenant or environment isolation)
REDIS_KEY_PREFIX=imu:dev:
# Use TLS for Redis connection (required for Redis Cloud, Azure Cache, etc.)
REDIS_TLS=false

# Cache Configuration (Generic Response Caching)
# Enable/disable Redis caching for API responses (default: true if REDIS_URL is set)
CACHE_ENABLED=true
# Cache TTL (time-to-live) in seconds: 300=5min, 1800=30min, 3600=1hour, 86400=24hours
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=3600
CACHE_TTL_DAY=86400

# IMU Client Cache TTLs (Specific to client caching implementation)
# Assigned client IDs cache (12 hours - 43200 seconds)
CACHE_TTL_ASSIGNED_CLIENT_IDS=43200
# Touchpoint summary cache (5 minutes - 300 seconds)
CACHE_TTL_TOUCHPOINT_SUMMARY=300
# User assigned areas cache (1 hour - 3600 seconds)
CACHE_TTL_ASSIGNED_AREAS=3600
# Cache stampede prevention lock (10 seconds)
CACHE_TTL_LOCK=10

# Queue Configuration
QUEUE_CONCURRENCY_BULK_OPERATIONS=5
QUEUE_CONCURRENCY_REPORTS=2
QUEUE_CONCURRENCY_LOCATIONS=3
QUEUE_CONCURRENCY_SYNC=10

# Mapbox Geocoding (server-side reverse geocoding for /api/geocode/reverse)
# When unset, the endpoint skips Mapbox and falls back to PSGC nearest-barangay.
MAPBOX_ACCESS_TOKEN=
